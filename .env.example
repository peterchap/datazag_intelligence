# datazag_intelligence — report generator config (runs on the dnsproject host)
# Copy to .env and fill in. .env is gitignored.

# riskscore intelligence service (Phase 1). Point at the riskscore host:port.
# Must be reachable from this host (private network / firewall allowing :8817).
INTELLIGENCE_BASE_URL=http://<riskscore-host>:8817
# Shared secret — MUST equal INTELLIGENCE_API_KEY set on the riskscore service.
INTELLIGENCE_API_KEY=<same-secret-as-riskscore>
# Optional: HTTP timeout in seconds (default 15).
#INTELLIGENCE_TIMEOUT=15

# Optional: where reports are written (default ./output).
#OUTPUT_DIR=/root/datazag_intelligence/output

# Note: --live runs dnsproject's scanner, which loads /root/dnsproject/.env for
# its own resolver / CertSpotter / RDAP config — that is configured separately.
