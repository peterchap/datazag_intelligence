[Unit]
Description=Datazag Free Threat Report Worker (public lead-gen reports)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/datazag_intelligence
# DATABASE_URL MUST point at the Customer Portal Neon DB. Also set PUBLIC_BASE_URL
# (e.g. https://datazag.com), RESEND_API_KEY, EMAIL_FROM.
EnvironmentFile=/root/datazag_intelligence/.env
ExecStart=/root/datazag_intelligence/venv/bin/python free_report_worker.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
